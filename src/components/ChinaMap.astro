---
import type { Lang } from "../config";
import { SITE } from "../config";
import { cities } from "../data/cities";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = SITE.base || "";

const mapLabels: Record<Lang, string> = {
  en: "Explore China",
  es: "Explorar China",
  de: "China entdecken",
  fr: "Explorer la Chine",
  ja: "中国を探索",
  ko: "중국 탐험",
};

const highlightLabel: Record<Lang, string> = {
  en: "Highlights",
  es: "Destacados",
  de: "Highlights",
  fr: "Points forts",
  ja: "見どころ",
  ko: "하이라이트",
};

function getCityCoords(id: string): [number, number] {
  const coords: Record<string, [number, number]> = {
    beijing: [116.41, 39.90],
    shanghai: [121.47, 31.23],
    guangzhou: [113.26, 23.13],
    chengdu: [104.07, 30.57],
    xian: [108.94, 34.26],
    guilin: [110.29, 25.27],
    hangzhou: [120.15, 30.27],
    chongqing: [106.55, 29.56],
    kunming: [102.83, 25.02],
    harbin: [126.63, 45.75],
    sanya: [109.51, 18.25],
    nanjing: [118.80, 32.06],
    suzhou: [120.62, 31.30],
    lhasa: [91.11, 29.65],
    xiamen: [118.09, 24.48],
  };
  return coords[id] || [116, 39];
}

const cityData = cities.map(c => ({
  id: c.id,
  name: c.name[lang],
  description: c.description[lang],
  highlights: c.highlights[lang],
  coords: getCityCoords(c.id),
}));
---

<section class="china-map-section">
  <div class="map-container">
    <div id="china-map-chart"></div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js" is:inline></script>
<script define:vars={{ cityData, base, highlightLabel: highlightLabel[lang] }} is:inline>
  (function() {
    function initMap() {
      if (typeof echarts === 'undefined') {
        setTimeout(initMap, 100);
        return;
      }

      var chartDom = document.getElementById('china-map-chart');
      if (!chartDom) return;

      fetch((base || '') + '/china.json')
        .then(function(res) { return res.json(); })
        .then(function(geoJson) {
          echarts.registerMap('china', geoJson);

          var chart = echarts.init(chartDom);

          var scatterData = cityData.map(function(c) {
            return { name: c.name, value: [c.coords[0], c.coords[1], c] };
          });

          var option = {
            tooltip: {
              trigger: 'item',
              backgroundColor: 'rgba(255,255,255,0.96)',
              borderColor: '#e2e8f0',
              borderWidth: 1,
              padding: [12, 16],
              textStyle: { color: '#1a1a2e', fontSize: 13 },
              formatter: function(params) {
                if (!params.data || !params.data.value || !params.data.value[2]) return '';
                var city = params.data.value[2];
                var highlights = city.highlights.join(' · ');
                return '<div style="min-width:200px">' +
                  '<div style="font-size:16px;font-weight:700;color:#2563eb;margin-bottom:6px">' + city.name + '</div>' +
                  '<div style="font-size:13px;color:#475569;margin-bottom:8px;line-height:1.5">' + city.description + '</div>' +
                  '<div style="font-size:12px;color:#64748b"><span style="font-weight:600">' + highlightLabel + ':</span> ' + highlights + '</div>' +
                  '</div>';
              },
            },
            geo: {
              map: 'china',
              roam: true,
              zoom: 1.2,
              center: [104, 35],
              scaleLimit: { min: 1, max: 8 },
              itemStyle: {
                areaColor: '#e8f4f8',
                borderColor: '#b0d4e8',
                borderWidth: 1,
              },
              emphasis: {
                itemStyle: { areaColor: '#d0e8f2' },
                label: { show: false },
              },
              regions: [
                { name: '南海诸岛', itemStyle: { opacity: 0 }, label: { show: false } },
              ],
            },
            series: [{
              type: 'effectScatter',
              coordinateSystem: 'geo',
              data: scatterData,
              symbolSize: 10,
              showEffectOn: 'emphasis',
              rippleEffect: { brushType: 'stroke', scale: 4 },
              itemStyle: {
                color: '#2563eb',
                shadowBlur: 10,
                shadowColor: 'rgba(37,99,235,0.3)',
              },
              emphasis: {
                itemStyle: { color: '#f59e0b' },
                scale: true,
              },
              label: {
                show: true,
                formatter: '{b}',
                position: 'right',
                fontSize: 11,
                color: '#334155',
                distance: 5,
              },
              zlevel: 1,
            }],
          };

          chart.setOption(option);
          window.addEventListener('resize', function() { chart.resize(); });
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMap);
    } else {
      initMap();
    }
  })();
</script>

<style>
  .china-map-section {
    margin: 2rem 0;
  }

  .china-map-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  .map-container {
    max-width: 800px;
    margin: 0 auto;
  }

  #china-map-chart {
    width: 100%;
    height: 500px;
  }

  @media (max-width: 640px) {
    #china-map-chart {
      height: 350px;
    }
  }
</style>
