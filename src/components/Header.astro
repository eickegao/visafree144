---
import { SITE, type Lang } from "../config";
import { t, getSwitchLangPath } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const nav = SITE.nav[lang];
const switchPath = getSwitchLangPath(Astro.url.pathname, lang);
---

<header>
  <div class="header-inner">
    <a href={lang === "zh" ? "/" : "/en/"} class="logo">
      <img src={SITE.author.avatar} alt={SITE.author.name[lang]} class="logo-avatar" onerror="this.style.display='none'" />
      <span>{SITE.title[lang]}</span>
    </a>
    <nav>
      {nav.map((item) => (
        <a href={item.href} class:list={[{ active: Astro.url.pathname === item.href }]}>
          {item.text}
        </a>
      ))}
      <a href={switchPath} class="lang-switch">{t(lang, "lang.switch")}</a>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid #e2e8f0;
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--text);
  }

  .logo:hover {
    color: var(--primary);
  }

  .logo-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  nav a {
    color: #64748b;
    font-size: 0.95rem;
  }

  nav a:hover, nav a.active {
    color: var(--primary);
  }

  .lang-switch {
    padding: 0.25rem 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .lang-switch:hover {
    border-color: var(--primary);
  }

  @media (max-width: 640px) {
    .header-inner {
      flex-direction: column;
      gap: 0.75rem;
    }
    nav {
      gap: 1rem;
    }
  }
</style>
