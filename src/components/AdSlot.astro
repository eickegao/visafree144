---
import { SITE } from "../config";

interface Props {
  slot: "top" | "bottom";
}

const { slot } = Astro.props;
const slotId = slot === "top" ? SITE.ads.articleTopSlot : SITE.ads.articleBottomSlot;
const showAd = SITE.ads.googleAdsenseId && slotId;
---

{showAd && (
  <div class="ad-container">
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={SITE.ads.googleAdsenseId}
      data-ad-slot={slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}

<style>
  .ad-container {
    margin: 1.5rem 0;
    text-align: center;
  }
</style>
