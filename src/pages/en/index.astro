---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { SITE } from "../../config";
import { t } from "../../i18n";
import { getBlogPosts } from "../../utils/blog";

const lang = "en";
const posts = await getBlogPosts(lang);
const latestPosts = posts.slice(0, 5);
---

<BaseLayout title={t(lang, "nav.home")} lang={lang}>
  <section class="hero">
    <img src={SITE.author.avatar} alt={SITE.author.name[lang]} class="avatar" onerror="this.style.display='none'" />
    <h1>{SITE.author.name[lang]}</h1>
    <p class="bio">{SITE.author.bio[lang]}</p>
  </section>

  <section class="latest">
    <div class="section-header">
      <h2>{t(lang, "home.latestPosts")}</h2>
      <a href="/en/blog/">{t(lang, "home.viewAll")} &rarr;</a>
    </div>
    {latestPosts.map((post) => (
      <ArticleCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        slug={post.id}
        tags={post.data.tags}
        lang={lang}
        body={post.body}
      />
    ))}
    {latestPosts.length === 0 && <p class="empty">No posts yet.</p>}
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0;
    border-bottom: 1px solid #e2e8f0;
    margin-bottom: 2rem;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
    border: 3px solid var(--primary);
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .bio {
    color: #64748b;
    max-width: 500px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
  }

  .empty {
    color: #94a3b8;
    text-align: center;
    padding: 2rem 0;
  }
</style>
