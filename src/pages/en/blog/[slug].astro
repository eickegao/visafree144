---
import { getCollection } from "astro:content";
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AdSlot from "../../../components/AdSlot.astro";
import { t, getLocalizedPath } from "../../../i18n";
import { formatDate, getReadingTime } from "../../../utils/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.lang === "en");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
const lang = "en";
const readingTime = post.body ? getReadingTime(post.body) : undefined;
---

<BaseLayout title={post.data.title} description={post.data.description} lang={lang} image={post.data.image} article={{ pubDate: post.data.pubDate, updatedDate: post.data.updatedDate, tags: post.data.tags }}>
  <article>
    <a href={getLocalizedPath("/blog/", lang)} class="back">&larr; {t(lang, "blog.backToBlog")}</a>
    <h1>{post.data.title}</h1>
    <div class="meta">
      <time>{formatDate(post.data.pubDate, lang)}</time>
      {readingTime && <span> · {readingTime} {t(lang, "blog.minRead")}</span>}
    </div>
    {post.data.tags.length > 0 && (
      <div class="tags">
        {post.data.tags.map((tag: string) => (
          <a href={getLocalizedPath(`/tags/${tag}/`, lang)} class="tag">#{tag}</a>
        ))}
      </div>
    )}

    <AdSlot slot="top" />

    <div class="prose">
      <Content />
    </div>

    <AdSlot slot="bottom" />
  </article>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: #64748b;
    font-size: 0.9rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .meta {
    color: #64748b;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--primary);
    background: var(--card-bg);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
</style>
